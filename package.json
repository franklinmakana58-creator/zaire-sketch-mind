{
  "name": "zaire-sketch-mind",
  "version": "1.0.0",
  "description": "AI-powered photorealistic design studio. Transform sketches and ideas into stunning photorealistic renders.",
  "main": "server/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch server/server.js",
    "start": "node server/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "migrate": "node server/scripts/migrate.js",
    "seed": "node server/scripts/seed.js",
    "worker": "node server/workers/imageGeneration.js",
    "docker:build": "docker build -t zaire-sketch-mind .",
    "docker:run": "docker run -p 3000:3000 --env-file .env zaire-sketch-mind"
  },
  "keywords": [
    "ai",
    "image-generation",
    "design",
    "photorealistic",
    "sketch-to-image",
    "flux",
    "stable-diffusion"
  ],
  "author": "franklinmakana58-creator",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-github2": "^0.1.12",
    "stripe": "^14.8.0",
    "bullmq": "^5.2.4",
    "ioredis": "^5.3.2",
    "socket.io": "^4.7.2",
    "sequelize": "^6.35.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "@aws-sdk/client-s3": "^3.445.0",
    "@aws-sdk/s3-request-presigner": "^3.445.0",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
